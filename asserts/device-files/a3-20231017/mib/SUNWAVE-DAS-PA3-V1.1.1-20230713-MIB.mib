deviceIpAddrNMS                OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "IP address1(CONSOLE) of device."
    ::= { wanIpSettings 12 }  
  
subnetMaskNMS              OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
