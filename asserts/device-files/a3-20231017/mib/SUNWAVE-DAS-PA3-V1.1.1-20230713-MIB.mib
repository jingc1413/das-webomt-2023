    ::= { trapAlarmObjects 17 } 

trapAliveObjects OBJECT IDENTIFIER ::= { traps 2 }	
trapAliveTime OBJECT-TYPE
    SYNTAX       DisplayString
    MAX-ACCESS    accessible-for-notify
    STATUS        current
    DESCRIPTION
        " alive trap time. 
        format: yyyy-mm-mm-dd hh:mm:ss, such as , 2013-07-20 16:07:50
        "
    ::= { trapAliveObjects 1 }  

trapAliveSiteName 				OBJECT-TYPE
    SYNTAX       DisplayString
    MAX-ACCESS    accessible-for-notify
    STATUS        current
    DESCRIPTION
        "The Name assigned to the originating Master Access Unit (SiteName)"
    ::= { trapAliveObjects 2 } 

trapAliveSequenceNo 				OBJECT-TYPE
    SYNTAX       Unsigned32
    MAX-ACCESS    accessible-for-notify
    STATUS        current
    DESCRIPTION
        "Sequence identifier is unique number for each alive trap. It is  incremented when a new alive trap is sent. 
        It ranges from 0 to 4294967296.
        "
    ::= { trapAliveObjects 3 } 

 trapAliveModuleID 				OBJECT-TYPE
    SYNTAX       DisplayString
    MAX-ACCESS    accessible-for-notify
    STATUS        current
    DESCRIPTION
        " Unique module identifier
        (based on this field the operator should be able to identify
        which module of which system is sending this alive trap)
        #deviceID#devicesubID"
    ::= { trapAliveObjects 4}


