-- network information

protocol       OBJECT-TYPE
    SYNTAX        INTEGER
    {
    	snmp(1),
    	udp(2)
    }
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION "Protocol Select
    SNMP or UDP
	  SNMP:1,UDP:2"
    ::= { wanIpSettings 1}  
    
primaryNMSIpAddress                OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "IP address of primary NMS."
    ::= { wanIpSettings 2 }  
 
primaryNMSPortNumber           OBJECT-TYPE
    SYNTAX        Integer32
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "primary NMS Port Number"
    ::= { wanIpSettings 3}  

secondaryNMSIpAddress                OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "IP address of secondary NMS."
    ::= { wanIpSettings 4 }  
 
secondaryNMSPortNumber           OBJECT-TYPE
    SYNTAX        Integer32
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "secondary NMS Port Number"
    ::= { wanIpSettings 5}  
        
deviceIpAddrCONSOLE                OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "IP address1(CONSOLE) of device."
    ::= { wanIpSettings 7 }  
  
subnetMaskCONSOLE              OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        " Subnet Mask1(CONSOLE) of device."
    ::= { wanIpSettings 8 }
    
deviceRecvPortForUDP           OBJECT-TYPE
    SYNTAX        Integer32
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "Device Port(UDP)"
