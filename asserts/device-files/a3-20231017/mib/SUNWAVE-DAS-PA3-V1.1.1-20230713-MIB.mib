   SUNWAVE-DAS-PA3-MIB DEFINITIONS ::= BEGIN
	IMPORTS
	OBJECT-TYPE, NOTIFICATION-TYPE, MODULE-IDENTITY,
	IpAddress,Integer32,Unsigned32,enterprises,TimeTicks
	FROM SNMPv2-SMI
	TEXTUAL-CONVENTION, MacAddress,DisplayString
	FROM SNMPv2-TC;
		
sunwave                OBJECT IDENTIFIER ::= { enterprises 31731}  
g3CrossFire        OBJECT IDENTIFIER ::= { sunwave 30}  

primaryA3     	         OBJECT IDENTIFIER ::= { g3CrossFire 1}
devlist	     	         OBJECT IDENTIFIER ::= { primaryA3 1}  

chanBaseBandPower    	 OBJECT IDENTIFIER ::= { systemInfo 16}       

a3Chan1InputBaseBandPower			 OBJECT-TYPE
 		  SYNTAX       Integer32    
      UNITS					"0.1dBm" 		  
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   " 
    	port1 Input BaseBand power value  
    	unit:0.1dbm, rate:10, 
    	for example: the value of 80 actually means 8dbm.    	    	"
    ::= { chanBaseBandPower 21 }        
    
a3Chan2InputBaseBandPower			 OBJECT-TYPE
 		  SYNTAX       Integer32    
      UNITS					"0.1dBm" 		  
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   " 
    	port2 Input BaseBand power value  
    	unit:0.1dbm, rate:10, 
    	for example: the value of 80 actually means 8dbm.    	    	"
    ::= { chanBaseBandPower 22 }    
    
a3Chan3InputBaseBandPower			 OBJECT-TYPE
 		  SYNTAX       Integer32    
      UNITS					"0.1dBm" 		  
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   " 
    	port3 Input BaseBand power value  
    	unit:0.1dbm, rate:10, 
    	for example: the value of 80 actually means 8dbm.    	    	"
    ::= { chanBaseBandPower 23 }  
    
a3Chan4InputBaseBandPower			 OBJECT-TYPE
 		  SYNTAX       Integer32    
      UNITS					"0.1dBm" 		  
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   " 
    	port4 Input BaseBand power value  
    	unit:0.1dbm, rate:10, 
    	for example: the value of 80 actually means 8dbm.    	    	"
    ::= { chanBaseBandPower 24 }      
        
a3Chan1OutputBaseBandPower			 OBJECT-TYPE
 		  SYNTAX       Integer32    
      UNITS					"0.1dBm" 		  
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   " 
    	port1 Output power value  
    	unit:0.1dbm, rate:10, 
    	for example: the value of 80 actually means 8dbm.    	    	"
    ::= { chanBaseBandPower 25 }      
        
a3Chan2OutputBaseBandPower			 OBJECT-TYPE
 		  SYNTAX       Integer32    
      UNITS					"0.1dBm" 		  
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   " 
    	port2 Output power value  
    	unit:0.1dbm, rate:10, 
    	for example: the value of 80 actually means 8dbm.    	    	"
