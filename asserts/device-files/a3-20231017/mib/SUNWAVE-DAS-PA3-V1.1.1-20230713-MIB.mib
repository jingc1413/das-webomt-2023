ntpSwitch             OBJECT-TYPE
    SYNTAX       INTEGER {
       		 	 off(0),
       			 on(1)
			}
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   "NTP switch. Note that AU time synchronizes to LMS when NTP switch is off."
    ::= { ntp 1 }

ntpUpdateInterval  OBJECT-TYPE
    SYNTAX       INTEGER(24..96)
    UNITS		 "hour"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "NTP Update Interval, ranges from 24 hour to 96 hour.
	rate:1 "
    ::= { ntp 2 }

timezone  OBJECT-TYPE
    SYNTAX        INTEGER
    {
        utc(0),
        utcEast1(1),
        utcEast2(2),
        utcEast3(3),
        utcEast4(4),
        utcEast5(5),
        utcEast6(6),
        utcEast7(7),
        utcEast8(8),
        utcEast9(9),
        utcEast10(10),
        utcEast11(11),
        utcEast12(12),
        utcWest1(13),
        utcWest2(14),
        utcWest(15),
        utcWest4(16),
        utcWest5(17),
        utcWest6(18),
        utcWest7(19),
        utcWest8(20),
        utcWest9(21),
        utcWest10(22),
        utcWest11(23),
        utcWest12(24)
    }
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION "time zone "
    ::= { ntp 3 }

ntpPrimaryServerIpAddress                OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "IP address of NTP primary server."
    ::= { ntp 4 }  

ntpSecondaryServerIpAddress                OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "IP address of NTP secondary server."
    ::= { ntp 5 }  


systemInfo 	           OBJECT IDENTIFIER ::= { primaryA3 5}
sysGeneral         	   OBJECT IDENTIFIER ::= { systemInfo 5}
elementOperatingTemperature	OBJECT-TYPE
    SYNTAX        Integer32
    UNITS	 			  "Celsius"
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION   "device temperature"
    ::= { sysGeneral 1 }

	
radioModule1Info               OBJECT IDENTIFIER ::= { systemInfo 1}

radioModule1RfSignalActive             OBJECT-TYPE
    SYNTAX       INTEGER {
       		 	 off(0),
       			 on(1)
			}
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   "RF signal switch of channel 1"
    ::= { radioModule1Info 1 }


radioModule1UlAttenuation		OBJECT-TYPE
    SYNTAX       INTEGER(0..40)
    UNITS					"0.25dB"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "Increase the value to decrease the up-link gain of channel 1.
    unit:0.25dB, 
    rate:4, for example: the value of 4 actually means 1dB.
    "
    ::= { radioModule1Info 2 }


radioModule1DlAttenuation		OBJECT-TYPE
    SYNTAX       INTEGER(0..20)
     UNITS					"0.5dB"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "Increase the value to decrease the down-link gain of channel 1 
    unit:0.5dB, 
    rate:2,  for example: the value of 2 actually means 1dB.
    "
    ::= { radioModule1Info 3 }

radioModule2Info               OBJECT IDENTIFIER ::= { systemInfo 2}
  
radioModule2RfSignalActive             OBJECT-TYPE
    SYNTAX       INTEGER {
       		 	 off(0),
       			 on(1)
			}
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION  "RF signal switch of channel 2"
    ::= { radioModule2Info 1 }


