-- sftpSettings
sftpSettings           OBJECT IDENTIFIER ::= { lanConnectivity 3}

serverIpAddress             OBJECT-TYPE
    SYNTAX        IpAddress
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "IP Address of the connected FTP Server for software upgrading."
    ::= { sftpSettings 1 }  

serverPortNumber           OBJECT-TYPE
    SYNTAX        Integer32
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "Server Port (FTP)"
    ::= { sftpSettings 2}   


