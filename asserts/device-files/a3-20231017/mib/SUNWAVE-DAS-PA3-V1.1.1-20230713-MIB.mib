--bandConfiguration      
bandConfiguration	      OBJECT IDENTIFIER ::= { primaryA3 7}

systemDelay                OBJECT IDENTIFIER ::= { bandConfiguration 1}
delayAdjustmentMethod			 OBJECT-TYPE
		SYNTAX       INTEGER    
		{   
        auto(0),
		trigger(1),
        manual(2)
		}
    	MAX-ACCESS    read-write
    	STATUS        current
    	DESCRIPTION   " 
    	Delay adjustment Method
    	"
    ::= { systemDelay 1 }            

maxDelayMeasuredValue		 OBJECT-TYPE
		SYNTAX       Integer32    
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   "
    	Maximum Delay Measurement Value
    	unit:0.01us, 
    	rate:100, for example: the value of 200 actually means 2us.
    	 "
    ::= { systemDelay 2 }        

maxDelayAdjustValue		 OBJECT-TYPE
		SYNTAX       Integer32    
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   "
    	Maximum Delay Adjustment Value    
    	unit:0.01us, 
    	rate:100, for example: the value of 200 actually means 2us.
    		 "
    ::= { systemDelay 3 }     

triggeredDelayActivation		 OBJECT-TYPE
		SYNTAX       INTEGER    
		{
			confirm(1)
		}
    	MAX-ACCESS    read-write
    	STATUS        current
    	DESCRIPTION   "
    	Manual Delay Confirm   
    	delayType must be manual mode  
    		 "
    ::= { systemDelay 4 }
	
customizeDelayValue		 OBJECT-TYPE
		SYNTAX       Integer32    
    	MAX-ACCESS    read-write
    	STATUS        current
    	DESCRIPTION   "
    	Customize Delay Value    
