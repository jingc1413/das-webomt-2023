    SYNTAX       INTEGER(0..40)
    UNITS					"0.25dB"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
     "Increase the value to decrease the up-link gain of channe2 
     unit:0.25dB, 
    rate:4, for example: the value of 4 actually means 1dB.
    "
    ::= { radioModule2Info 2 }


radioModule2DlAttenuation    	OBJECT-TYPE
    SYNTAX       INTEGER(0..20)
    UNITS					"0.5dB"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
     "Increase the value to decrease the down-link gain of channe2
     unit:0.5dB, 
    rate:2, for example: the value of 2 actually means 1dB.
    "
    ::= { radioModule2Info 3 }

