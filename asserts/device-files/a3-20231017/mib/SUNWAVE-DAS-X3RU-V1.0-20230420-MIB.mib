SUNWAVE-DAS-X3RU-MIB DEFINITIONS ::= BEGIN
	IMPORTS
	  OBJECT-TYPE, NOTIFICATION-TYPE, MODULE-IDENTITY,
	IpAddress,Integer32,Unsigned32,TimeTicks
	FROM SNMPv2-SMI
	TEXTUAL-CONVENTION,MacAddress,DisplayString
	FROM SNMPv2-TC
	enterprises FROM RFC1155-SMI ;
		
sunwave              OBJECT IDENTIFIER ::= { enterprises 31731} 
g3CrossFire      OBJECT IDENTIFIER ::= { sunwave 30}  

x3RU     	             OBJECT IDENTIFIER ::= { g3CrossFire 7}  

-- AlarmTable
alarms               OBJECT IDENTIFIER ::= { x3RU 2}
alarmTable OBJECT-TYPE
    SYNTAX        SEQUENCE OF AlarmEntry
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
        "Configure each possible alarm on the device (trap, relay out,
         severity...)."
    ::= { alarms 1 }    
    
alarmEntry OBJECT-TYPE
    SYNTAX        AlarmEntry
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
        "An entry containing one alarm informations."
    INDEX
        { alarmId }
    ::= { alarmTable 1 }
    
AlarmEntry ::= SEQUENCE
{   
    alarmId             INTEGER,
    alarmSeverity       INTEGER,
    alarmStat           INTEGER,
    alarmName   		DisplayString
}

alarmId OBJECT-TYPE
    SYNTAX        INTEGER(1..200) 
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
    "
       1:Power Interruption Alarm,
	   4:Over-temperature Alarm, 
       6: Optical Link Alarm,     
       28:OP S Transceiver Failure Alarm,
       29:OP M Transceiver Failure Alarm,
       30:Radio Module1 DL Output Over-power Alarm, 
       31:Radio Module2 DL Output Over-power Alarm, 
       32:Radio Module3 DL Output Over-power Alarm, 
       33:Radio Module4 DL Output Over-power Alarm, 
       34:Radio Module1 DL Output Under-power Alarm, 		
       35:Radio Module2 DL Output Under-power Alarm, 	
       36:Radio Module3 DL Output Under-power Alarm, 	
       37:Radio Module4 DL Output Under-power Alarm,
	   38:External Input Alarm 1,
	   39:External Input Alarm 2,
	   49:Module1 VSWR Alarm,
	   50:Module2 VSWR Alarm,
       51:Radio Module1 ALC Over Range Alarm,
       52:Radio Module2 ALC Over Range Alarm,
       53:Radio Module3 ALC Over Range Alarm,
       54:Radio Module4 ALC Over Range Alarm,
       87:Optical Port Switch Alarm,
	   96:Radio Module1 Open Load Alarm,
	   97:Radio Module2 Open Load Alarm,
	   144:Module3 VSWR Alarm,
	   145:Module4 VSWR Alarm,
	   159:Radio Module3 Open Load Alarm,
	   160:Radio Module4 Open Load Alarm,
	   165:Radio Module 1 Service OFF  Alarm,
	   166:Radio Module 2 Service OFF  Alarm,
	   167:Radio Module 3 Service OFF  Alarm,
	   168:Radio Module 4 Service OFF  Alarm
	"
    ::= { alarmEntry 1 }
  
alarmSeverity OBJECT-TYPE
    SYNTAX        INTEGER
    {
   		disable(0),
      warning(2),
      minor(3),
      major(4),
      critical(5)
     }
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
       "Alarm's level,if set it 0,device will not report this alarm"
    ::= { alarmEntry 2 }

alarmStat OBJECT-TYPE
   SYNTAX        INTEGER 
   {
      normal(0),
      alarm(1)
  } 
   MAX-ACCESS    read-only
   STATUS        current
   DESCRIPTION
      "Alarm's status"
   ::= { alarmEntry 3 }


        
alarmName OBJECT-TYPE
    SYNTAX        DisplayString
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION
        "Alarm's name;
         refer to the description of alarmId
        "
    ::= { alarmEntry 4 }
    
alarmTHD				 OBJECT IDENTIFIER ::= { alarms 2}
overTemperatureThreshold                OBJECT-TYPE
    SYNTAX        INTEGER (-55..125)
    UNITS	 			"Celsius"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of Over temperature Alarm.
    Alarm when device temperature over this threshold "
    ::= { alarmTHD 1 }

radioModule1OutputPowerUnderThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (190..520)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of module1 down link under output-power alarm.
    Alarm when the output power level of module1 is under this threshold.
    unit:0.1dBm,	rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 2 }

radioModule2OutputPowerUnderThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (190..520)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION    
    "the threshold of module2 down link under output-power alarm.
    Alarm when the output power level of module2 is under this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 3 }

radioModule3OutputPowerUnderThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (190..520)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of module1 down link under output-power alarm.
    Alarm when the output power level of module1 is under this threshold.
    unit:0.1dBm,	rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 4}

radioModule4OutputPowerUnderThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (190..520)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of module1 down link under output-power alarm.
    Alarm when the output power level of module1 is under this threshold.
    unit:0.1dBm,	rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 5 }
		
radioModule1OutputPowerOverThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (190..520)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of module1 down link over output-power alarm.
     Alarm when the output power level of module1 is over this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 6 }

radioModule2OutputPowerOverThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (190..520)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of module2 down link over output-power alarm.
    Alarm when the output power level of module2 is over this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 7 }

radioModule3OutputPowerOverThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (190..520)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of module1 down link over output-power alarm.
     Alarm when the output power level of module1 is over this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 8 }

radioModule4OutputPowerOverThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (190..520)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of module2 down link over output-power alarm.
    Alarm when the output power level of module2 is over this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 9 }
	
vswrThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (10..100)
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of VSWR.
     rate:10, 
    for example: the value of 25  actually means 2.5.
    "
    ::= { alarmTHD 10 }	
	
externalAlarm				 OBJECT IDENTIFIER ::= { alarms 3}
