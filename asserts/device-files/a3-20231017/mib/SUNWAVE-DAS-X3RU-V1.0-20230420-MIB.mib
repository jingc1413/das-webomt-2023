		}
    	MAX-ACCESS    read-write
    	STATUS        current
    	DESCRIPTION   " 
    	External 2 Alarm Mode Selection
    	0-normallyClosed
		1-normallyOpen
    	"
    ::= { externalAlarm 2 }	
	
