    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "
	Module4-C3 Carrier Switch,Turn off when not in use.
    "
    ::= { module4bandConfig 38 }

module4C4ULCentreFrequency		OBJECT-TYPE
		SYNTAX       Integer32
    UNITS					"0.001MHZ"
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION   
    "The carrier1 up-link center frequence of channel1.
    unit:0.001MHZ, 
    rate:1000, for example: the value of 800000 actually means 800MHz.
    "
    ::= { module4bandConfig 41 }
    

module4C4DLCentreFrequency		OBJECT-TYPE
		SYNTAX       Integer32
    UNITS					"0.001MHZ"
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION              		
    "The carrier1 down-link center frequence of channel1.
    unit:0.001MHZ, 
    rate:1000, for example: the value of 800000 actually means 800MHz.
    "
    ::= { module4bandConfig 42 }

module4C4DigitalSignalBandwidthSelect			 OBJECT-TYPE
		SYNTAX       INTEGER    
		{   
        custom(0),
		fiveMhz(5),
		tenMhz(10),
		fifteenMhz(15),
		twentyMhz(20),
		twentyfiveMhz(25),
		thirtyMhz(30),
		fortyMhz(40),
		fiftyMhz(50),
		sixtyMhz(60),
		seventyMhz(70),
		eightyMhz(80),
		ninetyMhz(90),
		onehundredMhz(100)
		}
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   " 
    	Bandwidth Selection
    	"
    ::= { module4bandConfig 43 }  

module4C4DigitalSignalBandwidth			OBJECT-TYPE
		SYNTAX       Integer32
    UNITS					"0.001MHZ"
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION   
    "The carrier1 bandwidth of channel1.
    unit:0.001MHZ, 
    rate:1000, for example: the value of 800000 actually means 800MHz.
    "
    ::= { module4bandConfig 44 }

module4C4CarrierSwitch			OBJECT-TYPE
	SYNTAX       INTEGER    
	{   
    off(0),
    on(1)
	}
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "
	Module4-C4 Carrier Switch,Turn off when not in use.
    "
    ::= { module4bandConfig 45 }	
	
