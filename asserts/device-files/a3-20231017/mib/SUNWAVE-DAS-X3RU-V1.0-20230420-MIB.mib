		SYNTAX       INTEGER    
		{   
        normallyClosed(0),
        normallyOpen(1)
		}
    	MAX-ACCESS    read-write
    	STATUS        current
    	DESCRIPTION   " 
    	External 1 Alarm Mode Selection
    	0-normallyClosed
		1-normallyOpen
    	"
    ::= { externalAlarm 1 }

