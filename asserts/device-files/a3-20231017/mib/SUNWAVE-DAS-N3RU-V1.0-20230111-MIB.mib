    	OP 1 Transceiver RX optical power    "
    ::= { opticalModuleInfo 63 }
 
oP2TransceiverRXpower         OBJECT-TYPE
    SYNTAX       Integer32
    UNITS		"0.01dBm" 
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION   
    "	rate:100
    	OP 2 Transceiver RX optical power    "
    ::= { opticalModuleInfo 64 }


--systemInfo    
systemInfo 	           OBJECT IDENTIFIER ::= { n3RU 5}
sysGeneral         	   OBJECT IDENTIFIER ::= { systemInfo 5}
deviceTemperature	OBJECT-TYPE
    SYNTAX        Integer32
    UNITS	 			  "Celsius"
    MAX-ACCESS    read-only
    STATUS        current
