chanBaseBandPower    	 OBJECT IDENTIFIER ::= { systemInfo 16}       

a3Chan1InputBaseBandPower			 OBJECT-TYPE
 		  SYNTAX       Integer32    
      UNITS					"0.1dBm" 		  
    	MAX-ACCESS    read-only
    	STATUS        current
    	DESCRIPTION   " 
    	port1 Input BaseBand power value  
    	unit:0.1dbm, rate:10, 
    	for example: the value of 80 actually means 8dbm.    	    	"
    ::= { chanBaseBandPower 21 }        
    
