-- AlarmTable
alarms                 OBJECT IDENTIFIER ::= { secondaryA3 2}
alarmTable OBJECT-TYPE
    SYNTAX        SEQUENCE OF AlarmEntry
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
        "Configure each possible alarm on the device (trap, relay out,
         severity...)."
    ::= { alarms 1 }

alarmEntry OBJECT-TYPE
    SYNTAX        AlarmEntry
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
        "An entry containing one alarm informations."
    INDEX
        { alarmId }
    ::= { alarmTable 1 }

AlarmEntry ::= SEQUENCE
{   
    alarmId             INTEGER,
    alarmSeverity       INTEGER,
    alarmStat           INTEGER,
    alarmName   		DisplayString
}

alarmId OBJECT-TYPE
    SYNTAX        INTEGER(1..200) 
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
	"   
        4:Over-temperature Alarm,  
        6:Optical Link Alarm, 
		20:OP1 Transceiver Failure Alarm, 
		38:External1 Alarm,
		39:External2 Alarm,
		51:Radio Module1 ALC Over Range Alarm,
		52:Radio Module2 ALC Over Range Alarm,
		53:Radio Module3 ALC Over Range Alarm,
		54:Radio Module4 ALC Over Range Alarm,
		55:Radio Module1 Port1 DL Input Under-power Alarm,
		56:Radio Module1 Port2 DL Input Under-power Alarm,
		57:Radio Module1 Port3 DL Input Under-power Alarm,
		58:Radio Module1 Port4 DL Input Under-power Alarm,
		59:Radio Module1 Port1 DL Input Over-power Alarm,
		60:Radio Module1 Port2 DL Input Over-power Alarm,
		61:Radio Module1 Port3 DL Input Over-power Alarm,
		62:Radio Module1 Port4 DL Input Over-power Alarm,
		63:Radio Module2 Port1 DL Input Under-power Alarm,
		64:Radio Module2 Port2 DL Input Under-power Alarm,
		65:Radio Module2 Port3 DL Input Under-power Alarm,
		66:Radio Module2 Port4 DL Input Under-power Alarm,
		67:Radio Module2 Port1 DL Input Over-power Alarm,
		68:Radio Module2 Port2 DL Input Over-power Alarm,
		69:Radio Module2 Port3 DL Input Over-power Alarm,
		70:Radio Module2 Port4 DL Input Over-power Alarm,
		71:Radio Module3 Port1 DL Input Under-power Alarm,
		72:Radio Module3 Port2 DL Input Under-power Alarm,
		73:Radio Module3 Port3 DL Input Under-power Alarm,
		74:Radio Module3 Port4 DL Input Under-power Alarm,
		75:Radio Module3 Port1 DL Input Over-power Alarm,
		76:Radio Module3 Port2 DL Input Over-power Alarm,
		77:Radio Module3 Port3 DL Input Over-power Alarm,
		78:Radio Module3 Port4 DL Input Over-power Alarm,
		79:Radio Module4 Port1 DL Input Under-power Alarm,
		80:Radio Module4 Port2 DL Input Under-power Alarm,
		81:Radio Module4 Port3 DL Input Under-power Alarm,
		82:Radio Module4 Port4 DL Input Under-power Alarm,
		83:Radio Module4 Port1 DL Input Over-power Alarm,
		84:Radio Module4 Port2 DL Input Over-power Alarm,
		85:Radio Module4 Port3 DL Input Over-power Alarm,
		86:Radio Module4 Port4 DL Input Over-power Alarm,
        163:FAN1 Alarm,
		164:FAN2 Alarm,
		165:Radio Module 1 Service OFF  Alarm,
		166:Radio Module 2 Service OFF  Alarm,
		167:Radio Module 3 Service OFF  Alarm,
		168:Radio Module 4 Service OFF  Alarm
	"
    ::= { alarmEntry 1 }
  
alarmSeverity OBJECT-TYPE
    SYNTAX        INTEGER
    {
   	  disable(0),
      warning(2),
      minor(3),
      major(4),
      critical(5)
     }
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
       "Alarm's level,if set it 0,device will not report this alarm"
    ::= { alarmEntry 2 }

alarmStat OBJECT-TYPE
   SYNTAX        INTEGER 
   {
      normal(0),
      alarm(1)
  } 
   MAX-ACCESS    read-only
   STATUS        current
   DESCRIPTION
      "Alarm's status"
   ::= { alarmEntry 3 }


        
alarmName OBJECT-TYPE
    SYNTAX        DisplayString
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION
        "Alarm's name;
         refer to the description of alarmId
        "
    ::= { alarmEntry 4 }
    

alarmTHD				 OBJECT IDENTIFIER ::= { alarms 2}
overTemperatureThreshold                OBJECT-TYPE
    SYNTAX        INTEGER (-55..125)
    UNITS	 			"Celsius"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of Over temperature Alarm.
    Alarm when device temperature over this threshold "
    ::= { alarmTHD 1 }

radioModule1InputPowerUnderThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (-200..200)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of radioModule1 down link under input-power alarm.
    Alarm when the input power level of radioModule1 is under this threshold.
    unit:0.1dBm,	rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 2 }

radioModule2InputPowerUnderThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (-200..200)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION    
    "the threshold of radioModule2 down link under input-power alarm.
    Alarm when the input power level of radioModule2 is under this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 3 }


radioModule3InputPowerUnderThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (-200..200)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION  
    "the threshold of radioModule3 down link under input-power alarm.
    Alarm when the input power level of radioModule3 is under this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 4}


radioModule4InputPowerUnderThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (-200..200)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of radioModule4 down link under input-power alarm.
    Alarm when the input power level of radioModule4 is under this threshold.
    unit:0.1dBm, rate:10,
     for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 5 }


radioModule1InputPowerOverThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (-200..200)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of radioModule1 down link over input-power alarm.
     Alarm when the input power level of radioModule1 is over this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 6 }


radioModule2InputPowerOverThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (-200..200)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of radioModule2 down link over input-power alarm.
    Alarm when the input power level of radioModule2 is over this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 7 }


radioModule3InputPowerOverThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (-200..200)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of radioModule3 down link over input-power alarm, 
    Alarm when the input power level of radioModule3 is over this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 8 }


radioModule4InputPowerOverThreshold          OBJECT-TYPE
    SYNTAX        Integer32 (-200..200)
    UNITS					"0.1dBm"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION   
    "the threshold of radioModule4 down link over input-power alarm,
    Alarm when the input power level of radioModule4 is over this threshold.
    unit:0.1dBm, rate:10, 
    for example: the value of 200 that sent or received actually means 20dBm.
    "
    ::= { alarmTHD 9 }
	
