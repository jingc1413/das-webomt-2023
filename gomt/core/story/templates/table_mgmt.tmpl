---- {{$col.Name}}{{if (eq $table.Unique $col.Key)}}, 数量={{getTableSize $table}}{{end}}
{{else if (eq $data.Type "Button") -}}
---- {{$col.Name}}{{if (eq $table.Unique $col.Key)}}, 数量={{getTableSize $table}}{{end}}
