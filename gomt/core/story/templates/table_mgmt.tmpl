{{if $toolbar -}}
## 工具栏定义
{{range $item := $toolbar.Items -}}
{{if (eq $item.Type "Button") -}}
--- {{$item.Name}}
{{else if (eq $item.Type "Param") -}}
{{$param := getParam $item -}}
---- {{$item.Name}}{{if $param}}, OID={{$param.PrivOid}}, 读写模式={{$param.Access}}, 数据类型={{$param.DataType}}, 字节数={{$param.ByteSize}}{{if $param.Ratio}}, 倍率={{$param.Ratio}}{{end}}{{if $param.Min}}, 最小值={{$param.Min}}{{end}}{{if $param.Max}}, 最大值={{$param.Max}}{{end}}{{end}}
